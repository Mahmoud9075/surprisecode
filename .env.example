# انسخ الملف ده وسمّيه .env واملأ القيم الحقيقية بتاعتك — ملف .env نفسه ماينفعش يترفع على GitHub

PORT=8080

# إيميل الأدمن الرئيسي وباسورد تطبيق Gmail (App Password، مش الباسورد العادي)
ADMIN_EMAIL=
GMAIL_APP_PASS=

# بيانات دخول الأدمن الأولى (بيتشفروا في قاعدة البيانات، مش بيتخزنوا كنص عادي)
ADMIN_USER=
ADMIN_PASS=

# نص عشوائي طويل وثابت لتوقيع جلسات الدخول — لو اتغيّر، كل الأدمنز هيتطلب منهم يدخلوا تاني
SESSION_SECRET=

# رابط قاعدة بيانات Neon (Postgres) — من لوحة تحكم Neon بعد ما تعمل مشروع جديد
DATABASE_URL=
